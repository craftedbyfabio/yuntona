{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "verbatimModuleSyntax": false
  },
  "include": [".astro/types.d.ts", "src/**/*"],
  "exclude": ["dist", "archive", "design ref 2.0", "node_modules"]
}
