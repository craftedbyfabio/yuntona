SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon-key>

# logo.dev publishable token (https://logo.dev). Used for tool logos.
# If unset, the directory + tool pages fall back to the 2-letter glyph.
PUBLIC_LOGO_DEV_TOKEN=<publishable-token>

# Typesense Cloud — hybrid + NL search
# HOST is publishable (the URL itself). ADMIN key is server-only and used only
# by scripts/sync-typesense.mjs at build time. SEARCH key is publishable
# (search-only, GET-only, collection-scoped) and reaches the client.
TYPESENSE_HOST=<cluster>.a1.typesense.net
TYPESENSE_ADMIN_KEY=<admin-key>
PUBLIC_TYPESENSE_SEARCH_KEY=<search-only-key>

# Gemini API key for Natural Language search parsing. Called by Typesense
# server-side via the nl_search_model — NEVER reaches the browser.
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<gemini-api-key>
