SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon-key>

# logo.dev publishable token (https://logo.dev). Used for tool logos.
# If unset, the directory + tool pages fall back to the 2-letter glyph.
PUBLIC_LOGO_DEV_TOKEN=<publishable-token>

# Typesense Cloud — hybrid + NL search
# Vite only inlines PUBLIC_*-prefixed env vars into client bundles, so the
# host needs both a server-side alias (TYPESENSE_HOST, used by the indexer
# script) AND a client-exposed copy (PUBLIC_TYPESENSE_HOST, used by the
# browser-side multi_search call). Same value in both. The ADMIN key stays
# server-only; the SEARCH key is publishable, search-only, GET-only.
TYPESENSE_HOST=<cluster>.a1.typesense.net
PUBLIC_TYPESENSE_HOST=<cluster>.a1.typesense.net
TYPESENSE_ADMIN_KEY=<admin-key>
PUBLIC_TYPESENSE_SEARCH_KEY=<search-only-key>

# Gemini API key for Natural Language search parsing. Called by Typesense
# server-side via the nl_search_model — NEVER reaches the browser.
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<gemini-api-key>
