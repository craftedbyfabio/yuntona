---
import '../styles/global.css';
import TopNav from '../components/TopNav.astro';
import Footer from '../components/Footer.astro';
import SearchPalette from '../components/SearchPalette.tsx';

type Props = {
  title: string;
  description?: string;
  current?: 'directory' | 'graph' | 'methodology';
};

const {
  title,
  description = 'Practitioner-curated directory of AI security tools, mapped to the OWASP LLM & Agentic Top 10.',
  current,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <script defer data-domain="yuntona.ai" src="/dv/js/script.js"></script>
  </head>
  <body>
    <TopNav current={current} />
    <main>
      <slot />
    </main>
    <Footer />
    <SearchPalette client:load />
    <script>
      document.addEventListener('click', (event) => {
        const target = event.target as HTMLElement | null;
        const trigger = target?.closest('[data-search-trigger]');
        if (trigger) {
          event.preventDefault();
          window.dispatchEvent(new CustomEvent('search-palette:open'));
        }
      });
    </script>
  </body>
</html>
