---
import YuntonaMark from './YuntonaMark.tsx';

type Props = { current?: 'directory' | 'graph' | 'methodology' };
const { current } = Astro.props;

const links: Array<{ label: string; href: string; key?: string }> = [
  { label: 'Directory',     href: '/directory',                                    key: 'directory' },
  { label: 'Graph',         href: '/graph',                                        key: 'graph' },
  { label: 'Methodology',   href: '/methodology',                                  key: 'methodology' },
  { label: 'GitHub ↗',      href: 'https://github.com/craftedbyfabio/yuntona' },
];
---

<nav class="topnav">
  <div class="inner">
    <a href="/" class="brand">
      <YuntonaMark size={26} color="#f0eee9" />
      <span class="wordmark">Yuntona</span>
      <span class="version">v1.7.0</span>
    </a>

    <div class="spacer"></div>

    <div class="links">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={['link', l.key && current === l.key && 'is-current']}
          aria-current={l.key && current === l.key ? 'page' : undefined}
        >
          {l.label}
        </a>
      ))}
    </div>

    <button class="search-cta" type="button" aria-label="Search" data-search-trigger>
      <span>Search</span>
      <kbd>⌘K</kbd>
    </button>
  </div>
</nav>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(10, 14, 20, 0.92);
    backdrop-filter: blur(16px) saturate(140%);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 14px var(--page-pad-x);
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.4px;
  }

  .version {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-faint);
    letter-spacing: 1px;
    margin-top: 2px;
  }

  .spacer { flex: 1; }

  .links {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    color: var(--text-dim);
    font-family: var(--font-body);
  }

  .link {
    color: var(--text-muted);
    text-decoration: none;
    padding: 8px 14px;
    border-radius: 6px;
    transition: background 0.12s, color 0.12s;
  }
  .link:hover { background: rgba(255, 255, 255, 0.05); color: var(--text); }
  .link.is-current { color: var(--text); }

  .search-cta {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--coral);
    color: var(--bg);
    border: none;
    padding: 9px 16px;
    border-radius: 7px;
    cursor: pointer;
    font-weight: 600;
    letter-spacing: 0.2px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .search-cta kbd {
    background: rgba(10, 14, 20, 0.18);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 10px;
    font-family: inherit;
    color: var(--bg);
  }

  @media (max-width: 768px) {
    .links { display: none; }
    .version { display: none; }
  }
</style>
