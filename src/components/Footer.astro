---
import YuntonaMark from './YuntonaMark.tsx';

const cols: Array<{ title: string; links: Array<[string, string]> }> = [
  { title: 'Platform',   links: [['Directory', '/directory'], ['Knowledge Graph', '/graph']] },
  { title: 'Resources',  links: [['Methodology', '/methodology'], ['GitHub', 'https://github.com/craftedbyfabio/yuntona']] },
  { title: 'Contribute', links: [
    ['Suggest a tool',   'https://github.com/craftedbyfabio/yuntona/issues/new?labels=tool-suggestion&title=Tool+suggestion%3A+%5Btool+name%5D&body=See+CONTRIBUTING.md+for+the+schema.%0A%0A**Tool+name+%2B+URL%3A**%0A%0A**Category%3A**%0A%0A**Why+it+belongs+%28one+sentence%29%3A**%0A%0A**OWASP+LLM+risks+it+addresses%3A**%0A'],
    ['Report an issue',  'https://github.com/craftedbyfabio/yuntona/issues/new?labels=bug'],
    ['Star on GitHub',   'https://github.com/craftedbyfabio/yuntona'],
  ] },
];
---

<footer class="footer">
  <div class="grid">
    <div class="brand-col">
      <div class="brand">
        <YuntonaMark size={24} color="#f0eee9" />
        <span class="wordmark">Yuntona<span class="tm">™</span></span>
      </div>
      <p class="blurb">
        Practitioner-curated directory of AI security controls, mapped to the OWASP LLM &amp; Agentic Top 10.
      </p>
      <div class="meta">Open Source · Made in the UK</div>
    </div>

    {cols.map((c) => (
      <div class="link-col">
        <div class="col-title">{c.title}</div>
        {c.links.map(([label, href]) => {
          const external = href.startsWith('http');
          return (
            <a
              class="footer-link"
              href={href}
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
            >
              {label}
            </a>
          );
        })}
      </div>
    ))}
  </div>

  <div class="bottom">
    <span>© 2026 Yuntona Ltd · All rights reserved</span>
    <span>v1.7.0 · 161 tools · last updated 2026-04-22</span>
  </div>
</footer>

<style>
  .footer {
    padding: 48px var(--page-pad-x) 36px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(0, 0, 0, 0.2);
  }
  .grid {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .wordmark {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--text);
    font-weight: 600;
    letter-spacing: -0.3px;
  }
  .tm {
    font-size: 0.55em;
    opacity: 0.45;
    vertical-align: super;
    font-weight: 400;
    margin-left: 2px;
  }
  .blurb {
    color: var(--text-faint);
    font-size: 13px;
    line-height: 1.6;
    margin: 0;
    max-width: 320px;
  }
  .meta {
    margin-top: 18px;
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--text-faint);
    letter-spacing: 0.3px;
  }

  .col-title {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-faint);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .footer-link {
    display: block;
    color: var(--text-muted);
    font-size: 13px;
    text-decoration: none;
    padding: 4px 0;
    transition: color 0.12s;
  }
  .footer-link:hover { color: var(--coral); }

  .bottom {
    max-width: var(--container-max);
    margin: 36px auto 0;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--text-faint);
    letter-spacing: 0.3px;
  }

  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; gap: 24px; }
    .bottom { flex-direction: column; gap: 8px; }
  }
</style>
