---
type Props = { label: string };
const { label } = Astro.props;
---

<div class="section-label">
  <span class="bar"></span>
  <span>{label}</span>
</div>

<style>
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--coral);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .bar {
    width: 20px;
    height: 1px;
    background: var(--coral);
  }
</style>
