---
import YuntonaMark from '../YuntonaMark.tsx';
---

<section class="cta">
  <div class="bg" aria-hidden="true"></div>
  <div class="inner">
    <div class="mark">
      <YuntonaMark size={64} color="#7fb8aa" />
    </div>
    <h2 class="title">
      Close the blind spots<br />
      in your <em class="italic-accent">AI risk coverage</em>.
    </h2>
    <p class="copy">
      161 dedicated AI security tools, frameworks and standards. 20 OWASP risks. One search.
    </p>
    <div class="buttons">
      <a href="/directory" class="primary">
        Explore directory
        <span class="arrow">→</span>
      </a>
      <a href="https://github.com/craftedbyfabio/yuntona" class="ghost">★ Star on GitHub</a>
    </div>
    <div class="meta">
      <span>OWASP LLM Top 10 · 2025</span>
      <span>·</span>
      <span>OWASP Agentic Top 10 · 2026</span>
      <span>·</span>
      <span>Open Source · MIT</span>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 120px 32px;
    position: relative;
    overflow: hidden;
  }
  .bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse 700px 400px at 50% 50%, rgba(201, 100, 66, 0.08), transparent 70%);
  }
  .inner {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }
  .mark {
    display: flex;
    justify-content: center;
    margin-bottom: 32px;
    opacity: 0.85;
  }
  .title {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 500;
    letter-spacing: -1.6px;
    line-height: 1.05;
    color: var(--text);
    margin: 0 0 24px;
  }
  .copy {
    font-size: 18px;
    color: var(--text-dim);
    line-height: 1.55;
    max-width: 560px;
    margin: 0 auto 40px;
  }
  .buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .primary {
    background: var(--coral);
    color: var(--bg);
    padding: 15px 26px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .arrow { font-family: var(--font-mono); }
  .ghost {
    background: transparent;
    color: var(--text-muted);
    padding: 15px 26px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.15);
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .meta {
    margin-top: 56px;
    display: flex;
    gap: 24px;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
    letter-spacing: 0.5px;
    flex-wrap: wrap;
  }

  @media (max-width: 720px) {
    .title { font-size: 40px; letter-spacing: -1px; }
  }
</style>
